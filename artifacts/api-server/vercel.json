{
  "version": 2,
  "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "buildCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile && pnpm --filter @workspace/api-server run build:vercel",
  "outputDirectory": "dist-vercel",
  "functions": {
    "dist-vercel/index.mjs": {
      "maxDuration": 300,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/dist-vercel/index.mjs" }
  ]
}
