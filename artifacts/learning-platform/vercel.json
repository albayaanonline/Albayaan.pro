{
  "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "buildCommand":   "node build-api.mjs && pnpm run build",
  "outputDirectory": "dist",
  "framework": "vite",

  "functions": {
    "api/backend.mjs": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/storage/upload-url.ts": {
      "maxDuration": 30
    }
  },

  "rewrites": [
    { "source": "/api/storage/upload-url", "destination": "/api/storage/upload-url" },
    { "source": "/api/:path*",             "destination": "/api/backend.mjs" },
    { "source": "/(.*)",                   "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],

  "env": {
    "PORT":      "3000",
    "BASE_PATH": "/"
  }
}
