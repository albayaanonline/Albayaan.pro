{
  "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "buildCommand":   "pnpm run build",
  "outputDirectory": "dist",
  "framework": "vite",

  "functions": {
    "api/auth/[action].ts":                   { "maxDuration": 15 },
    "api/contact.ts":                         { "maxDuration": 10 },
    "api/courses.ts":                         { "maxDuration": 15 },
    "api/courses/[courseId].ts":              { "maxDuration": 10 },
    "api/codes/redeem.ts":                    { "maxDuration": 15 },
    "api/payments/submit.ts":                 { "maxDuration": 10 },
    "api/progress/index.ts":                  { "maxDuration": 10 },
    "api/certificates/[certId].ts":           { "maxDuration": 10 },
    "api/storage/upload-url.ts":              { "maxDuration": 30 },
    "api/admin/courses.ts":                   { "maxDuration": 15 },
    "api/admin/courses/[courseId].ts":        { "maxDuration": 10 },
    "api/admin/manage.ts":                    { "maxDuration": 10 }
  },

  "rewrites": [
    { "source": "/api/auth/:action",                           "destination": "/api/auth/[action]" },
    { "source": "/api/contact",                                "destination": "/api/contact" },
    { "source": "/api/courses",                                "destination": "/api/courses" },
    { "source": "/api/courses/:courseId",                      "destination": "/api/courses/[courseId]" },
    { "source": "/api/codes/redeem",                           "destination": "/api/codes/redeem" },
    { "source": "/api/payments/submit",                        "destination": "/api/payments/submit" },
    { "source": "/api/progress",                               "destination": "/api/progress/index" },
    { "source": "/api/certificates/:certId",                   "destination": "/api/certificates/[certId]" },
    { "source": "/api/storage/upload-url",                     "destination": "/api/storage/upload-url" },
    { "source": "/api/admin/stats",                            "destination": "/api/admin/manage?type=stats" },
    { "source": "/api/admin/users",                            "destination": "/api/admin/manage?type=users" },
    { "source": "/api/admin/payments",                         "destination": "/api/admin/manage?type=payments" },
    { "source": "/api/admin/codes",                            "destination": "/api/admin/manage?type=codes" },
    { "source": "/api/admin/courses",                          "destination": "/api/admin/courses" },
    { "source": "/api/admin/courses/:courseId/publish",        "destination": "/api/admin/courses/[courseId]?sub=publish" },
    { "source": "/api/admin/courses/:courseId/lessons",        "destination": "/api/admin/courses/[courseId]?sub=lessons" },
    { "source": "/api/admin/courses/:courseId",                "destination": "/api/admin/courses/[courseId]" },
    { "source": "/((?!api/).*)",                               "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],

  "env": {
    "PORT":      "3000",
    "BASE_PATH": "/"
  }
}
